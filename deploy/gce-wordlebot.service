[Unit]
Description=Wordle Seasons Bot
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/wordle-seasons
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose up --build -d prod
ExecStop=/usr/bin/docker compose stop prod
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
